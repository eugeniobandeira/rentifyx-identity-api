# Local development environment template
# Copy to .env.local and adjust as needed.
# These values are used when running via Aspire (dotnet run --project 01-aspire/01-AppHost/...)
#
# LocalStack was removed — the API now talks to real AWS resources even for local
# development. Provision them first (see iac/terraform), then destroy after testing.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1

# Alternatively, set AWS_PROFILE to a named profile configured in ~/.aws/credentials
# instead of raw access keys.
#
# AWS_PROFILE=rentifyx-admin

# Secrets (Jwt:PrivateKeyPem, Hmac:Key, Ses:FromAddress) are loaded from Secrets Manager
# at "rentifyx/identity/{environment}" — seed the secret value after `terraform apply`
# (see iac/terraform/modules/secrets), it deploys with REPLACE_AT_DEPLOY_TIME placeholders.
#
# ASPNETCORE_ENVIRONMENT=Development   (default when running via Aspire)
