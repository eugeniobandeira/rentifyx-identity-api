# Local development environment template
# Copy to .env.local and adjust as needed.
# These values are used when running via Aspire (dotnet run --project 01-aspire/01-AppHost/...)
#
# LocalStack handles all AWS services locally — no real AWS credentials are needed.
# The fake key/secret below are the LocalStack defaults and must not be changed.

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=sa-east-1

# The init script (01-aspire/01-AppHost/scripts/init-localstack.sh) seeds this secret
# automatically on LocalStack startup. Override only if you need a fixed HMAC key or
# a specific JWT private key for debugging.
#
# ASPNETCORE_ENVIRONMENT=Development   (default when running via Aspire)
