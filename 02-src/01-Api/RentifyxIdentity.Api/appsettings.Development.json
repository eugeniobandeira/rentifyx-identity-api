{
  "AWS": {
    "Region": "sa-east-1",
    "SecretsManager": {
      "SecretName": "rentifyx/identity/{environment}"
    },
    "DynamoDB": {
      "TableName": "rentifyx-development-identity"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  }
}
