{
  "LocalStack": {
    "UseLocalStack": true,
    "Config": {
      "LocalStackHost": "localhost",
      "EdgePort": 4566,
      "UseSsl": false
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  }
}
